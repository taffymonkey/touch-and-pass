{
  "expo": {
    "name": "Fifty22",
    "slug": "fifty22",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/fifty22-light-1024x1024.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/fifty22-light-1024x1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sportivelogic.pitchside",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      },
      "entitlements": {
        "aps-environment": "production",
        "com.apple.security.application-groups": [
          "group.com.sportivelogic.pitchside.onesignal"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/fifty22-light-1024x1024.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.sportivelogic.fiftytwentytwo",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/newly.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "production"
        }
      ],
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "fifty22",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://ggr5mw498a2953kypgkfkkwsubrg5vu2.app.specular.dev",
      "oneSignalAppId": "b0b1dae7-3bf7-4801-90be-a1fe1e4c4dcb"
    }
  }
}